{
  "schemaVersion": 1,
  "id": "nohotbarswap",
  "version": "${version}",
  "name": "No Hotbar Swap",
  "description": "Prevent accidental hotbar swapping when pressing number keys in inventory!",
  "authors": [
    "Mercuri"
  ],
  "contact": {
    "homepage": "https://github.com/mercuri/nohotbarswap",
    "sources": "https://github.com/mercuri/nohotbarswap"
  },
  "license": "MIT",
  "icon": "assets/nohotbarswap/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.mercuri.nohotbarswap.fabric.FabricMod"
    ],
    "client": [
      "com.mercuri.nohotbarswap.fabric.client.FabricClientMod"
    ]
  },
  "mixins": [
    "nohotbarswap.fabric.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.5",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  },
  "suggests": {
    "modmenu": "*",
    "cloth-config": "*"
  }
}